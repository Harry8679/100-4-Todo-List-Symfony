{% extends 'base.html.twig' %}

{% block title %}Accueil — {{ prenom }}{% endblock %}

{% block body %}

<div class="max-w-2xl mx-auto px-6 py-16">

    <h1 class="text-4xl font-bold text-gray-900 mb-2">
        Bonjour, je suis {{ prenom }} 👋
    </h1>

    <p class="text-xl text-gray-500 mb-8">
        {{ metier }}
    </p>

    {# ------------------------------------------------
       CONDITION {% if %} / {% else %} / {% endif %}
       On affiche un badge différent selon "disponible"
       ------------------------------------------------ #}

    {% if disponible %}

        <div class="inline-flex items-center gap-2 bg-green-100 text-green-700 px-4 py-2 rounded-full text-sm font-medium">
            <span class="w-2 h-2 bg-green-500 rounded-full"></span>
            Disponible pour des projets
        </div>

    {% else %}

        <div class="inline-flex items-center gap-2 bg-red-100 text-red-700 px-4 py-2 rounded-full text-sm font-medium">
            <span class="w-2 h-2 bg-red-500 rounded-full"></span>
            Non disponible actuellement
        </div>

    {% endif %}

    <div class="mt-10">
        <a href="{{ path('app_projets') }}"
           class="bg-gray-900 text-white px-6 py-3 rounded-xl text-sm font-semibold hover:bg-gray-700">
            Voir mes projets →
        </a>
    </div>

</div>

{% endblock %}
